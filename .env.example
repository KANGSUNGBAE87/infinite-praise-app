# Public client env. These may be exposed to the browser after Supabase RLS and
# Edge Function policies are verified.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=replace-with-your-public-anon-key

GEMINI_API_KEY=replace-with-your-gemini-api-key

# Server-only. Do not expose these as VITE_/PUBLIC_/NEXT_PUBLIC_ variables.
# In production, set DEEPSEEK_API_KEY as a Supabase Edge Function secret.
DEEPSEEK_API_KEY=replace-with-your-server-only-deepseek-api-key
SUPABASE_URL=replace-with-your-server-side-supabase-url
SUPABASE_SERVICE_ROLE_KEY=replace-with-your-server-only-service-role-key
SUPABASE_REPORTS_TABLE=praise_candidate_reports
